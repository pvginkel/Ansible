# Managed by Ansible (baseline role).
# Paired with the public-DNS netplan render: hosts whose
# network_devices declare explicit nameservers resolve through
# public upstreams (eth0 / +DefaultRoute) and use this drop-in to
# resolve .home via the in-cluster dnsmasq LBs.
#
# `home` is a search + routing domain here (not `~home`) so this scope
# owns .home outright. The netplan render deliberately carries no
# `search:` on the public-DNS link: a per-link `home` search domain
# there pins to the public upstreams, ties with this scope on suffix
# length, and the public NXDOMAIN for .home shadows the dnsmasq answer
# — intermittent resolution failures, made sticky by the negative
# cache. Keeping the suffix on the dnsmasq scope means both
# single-label completion and .home routing land on the resolver that
# actually knows .home. See slices/completed/home-dns-routing.md.
[Resolve]
DNS={{ baseline_home_dns_routing_servers | join(' ') }}
Domains=home
