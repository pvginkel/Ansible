# {{ ansible_managed }}
# Managed by Ansible — roles/openbao. Edits on the node will be
# overwritten on the next converge.

ui = true

# disable_mlock = true matches OpenBao's integrated-storage guidance
# (Raft writes keys to disk anyway, so mlock'ing the process gives
# little extra protection) and the .deb's bundled systemd unit, which
# omits CAP_IPC_LOCK from its CapabilityBoundingSet and sets
# MemorySwapMax=0 so swap is off at the cgroup level.
disable_mlock = true

storage "raft" {
  path    = "{{ openbao_data_dir }}/raft"
  node_id = "{{ inventory_hostname }}"
}

listener "tcp" {
  address         = "{{ openbao_listener_address }}"
  cluster_address = "{{ ansible_facts.default_ipv4.address }}:8201"
  tls_cert_file   = "{{ openbao_tls_cert_path }}"
  tls_key_file    = "{{ openbao_tls_key_path }}"
  # Stop the listener from advertising optional client-cert auth in
  # the TLS handshake, which makes browsers prompt the operator to
  # pick a client cert. We don't use TLS cert-auth — AppRole is the
  # only auth method enabled.
  tls_disable_client_certs = "true"
}

seal "static" {
  current_key_id = "{{ openbao_seal_current_key_id }}"
  current_key    = "file://{{ openbao_seal_key_path }}"
}

api_addr     = "{{ openbao_api_addr }}"
cluster_addr = "{{ openbao_cluster_addr }}"

# File audit device. OpenBao 2.5 rejects the API enable path
# (sys/audit) with "cannot enable audit device via API; use
# declarative, config-based audit device management instead", so the
# device is declared here. The parent directory is created by
# tasks/audit.yml so the daemon can open the append-only log on
# first start.
audit "file" "{{ openbao_audit_path }}" {
  description = "homelab audit log — managed by the openbao role"
  options {
    file_path = "{{ openbao_audit_file_path }}"
  }
}
