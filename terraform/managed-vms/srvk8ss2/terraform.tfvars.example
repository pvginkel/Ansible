# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# Or set TF_VAR_proxmox_api_token / TF_VAR_proxmox_endpoint in the shell so
# every per-VM module under terraform/managed-vms/ picks up the same value.

proxmox_endpoint  = "https://pve.home:8006/"
proxmox_api_token = "terraform@pve!automation=REPLACE-ME"
proxmox_insecure  = true
