# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
#
# The api token comes from the runbook at docs/runbooks/proxmox-api-token.md.
# The ansible public key is read from the repo automatically
# (ansible/roles/bootstrap/files/ansible.pub); no need to set it here unless
# you want to override it for a one-off run.

proxmox_endpoint  = "https://pve.home:8006/"
proxmox_api_token = "terraform@pve!automation=REPLACE-WITH-SECRET"
proxmox_insecure  = true

# pve has cores 0-11 zoned for interactive workloads and 12-19 for background.
# Empty / unset means no pinning (correct for nodes you haven't zoned).
vm_cpu_affinity = "0-11"
